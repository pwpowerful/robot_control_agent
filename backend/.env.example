RCA_APP_NAME=robot-control-backend
RCA_APP_ENV=development
RCA_APP_HOST=127.0.0.1
RCA_APP_PORT=8000
RCA_RELOAD=false
RCA_LOG_LEVEL=INFO
RCA_LOG_FORMAT=json
RCA_DATABASE_URL=postgresql+psycopg://robot_user:change-me@127.0.0.1:5432/robot_control
RCA_DATABASE_CONNECTIVITY_CHECK=false
RCA_DATABASE_CONNECTIVITY_TIMEOUT_SECONDS=3
RCA_MODEL_PROVIDER_NAME=shared_api
RCA_SHARED_MODEL_NAME=shared-default
RCA_SHARED_MODEL_BASE_URL=
RCA_SHARED_MODEL_API_KEY=
RCA_SHARED_MODEL_TIMEOUT_SECONDS=20
RCA_SHARED_MODEL_MAX_RETRIES=1
RCA_SHARED_MODEL_ORGANIZATION=
RCA_VISION_ADAPTER_MODE=simulated
RCA_VISION_BACKEND=mock_vision
RCA_VISION_REQUEST_TIMEOUT_SECONDS=5
RCA_VISION_CALIBRATION_FILE=
RCA_ROBOT_ADAPTER_MODE=simulated
RCA_ROBOT_BACKEND=mock_robot
RCA_ROBOT_COMMAND_TIMEOUT_SECONDS=10
RCA_ROBOT_CONTROL_ENDPOINT=
RCA_EXECUTION_ALLOW_REAL_HARDWARE=false
RCA_EXECUTION_ROBOT_CONFIG_ID=
RCA_SAFETY_RULE_SET_ID=
RCA_SAFETY_MAX_TASK_DURATION_SECONDS=60
RCA_SAFETY_EMERGENCY_STOP_ENABLED=true
RCA_AUTH_SESSION_COOKIE_NAME=rca_session
RCA_AUTH_SESSION_TTL_MINUTES=480
RCA_AUTH_REQUIRE_SECURE_COOKIES=false
RCA_AUTH_COOKIE_SAME_SITE=lax
RCA_AUTH_ADMIN_USERNAME=admin
RCA_AUTH_ADMIN_PASSWORD=change-me-admin
RCA_AUTH_OPERATOR_USERNAME=operator
RCA_AUTH_OPERATOR_PASSWORD=change-me-operator
RCA_AUDIT_ENABLED=true
RCA_AUDIT_EVENT_RETENTION_DAYS=90
RCA_AUDIT_STORE_RAW_REASONING=false
RCA_ARTIFACT_ROOT_DIR=runtime/artifacts
RCA_ARTIFACT_AUTO_CREATE=true

# Optional JSON overrides. Leave unset to keep the conservative defaults in settings.py.
# RCA_SAFETY_FORBIDDEN_ZONES=[{"name":"human_access_zone","frame":"workspace","min_corner":[-0.8,-0.8,-0.1],"max_corner":[0.8,0.8,1.8]}]
# RCA_SAFETY_JOINT_LIMITS={"joint_1":{"minimum_degrees":-150,"maximum_degrees":150}}
