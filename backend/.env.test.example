RCA_APP_ENV=test
RCA_LOG_LEVEL=WARNING
RCA_LOG_FORMAT=console
RCA_DATABASE_URL=postgresql+psycopg://robot_user:change-me@127.0.0.1:5432/robot_control_test
RCA_DATABASE_CONNECTIVITY_CHECK=false
RCA_SHARED_MODEL_NAME=shared-default
RCA_VISION_ADAPTER_MODE=simulated
RCA_ROBOT_ADAPTER_MODE=simulated
RCA_SAFETY_MAX_TASK_DURATION_SECONDS=60
RCA_SAFETY_EMERGENCY_STOP_ENABLED=true
RCA_AUTH_ADMIN_USERNAME=admin
RCA_AUTH_ADMIN_PASSWORD=change-me-admin
RCA_AUTH_OPERATOR_USERNAME=operator
RCA_AUTH_OPERATOR_PASSWORD=change-me-operator
RCA_ARTIFACT_ROOT_DIR=runtime/test-artifacts
