RCA_APP_ENV=production
RCA_APP_HOST=0.0.0.0
RCA_APP_PORT=8000
RCA_LOG_LEVEL=INFO
RCA_LOG_FORMAT=json
RCA_DATABASE_URL=postgresql+psycopg://robot_user:change-me@localhost:5432/robot_control
RCA_DATABASE_CONNECTIVITY_CHECK=true
RCA_DATABASE_CONNECTIVITY_TIMEOUT_SECONDS=3
RCA_MODEL_PROVIDER_NAME=shared_api
RCA_SHARED_MODEL_NAME=shared-default
RCA_SHARED_MODEL_BASE_URL=
RCA_SHARED_MODEL_API_KEY=replace-me
RCA_SHARED_MODEL_TIMEOUT_SECONDS=20
RCA_SHARED_MODEL_MAX_RETRIES=1
RCA_VISION_ADAPTER_MODE=simulated
RCA_ROBOT_ADAPTER_MODE=simulated
RCA_SAFETY_MAX_TASK_DURATION_SECONDS=60
RCA_SAFETY_EMERGENCY_STOP_ENABLED=true
RCA_AUTH_REQUIRE_SECURE_COOKIES=true
RCA_AUTH_COOKIE_SAME_SITE=lax
RCA_AUTH_ADMIN_USERNAME=admin
RCA_AUTH_ADMIN_PASSWORD=replace-admin-password
RCA_AUTH_OPERATOR_USERNAME=operator
RCA_AUTH_OPERATOR_PASSWORD=replace-operator-password
RCA_AUDIT_ENABLED=true
RCA_AUDIT_EVENT_RETENTION_DAYS=180
RCA_AUDIT_STORE_RAW_REASONING=false
RCA_ARTIFACT_ROOT_DIR=C:/robot-control-agent/runtime/artifacts
RCA_ARTIFACT_AUTO_CREATE=true

# Required before any real hardware or real vision adapter can be enabled:
# RCA_EXECUTION_ALLOW_REAL_HARDWARE=true
# RCA_EXECUTION_ROBOT_CONFIG_ID=robot-config-prod
# RCA_SAFETY_RULE_SET_ID=safety-default
# RCA_ROBOT_CONTROL_ENDPOINT=https://robot-controller.internal/control
# RCA_VISION_CALIBRATION_FILE=C:/robot-control-agent/calibration/camera.json
